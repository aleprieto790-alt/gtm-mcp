# GTM-MCP API Keys
# Copy to .env and fill in your keys:  cp .env.example .env
# This file is NOT tracked by git

# Required — Apollo is the primary data source
GTM_MCP_APOLLO_API_KEY=

# Required for campaign creation/sending
GTM_MCP_SMARTLEAD_API_KEY=

# Optional — LinkedIn outreach via GetSales
GTM_MCP_GETSALES_API_KEY=
GTM_MCP_GETSALES_TEAM_ID=

# User email — receives test emails from SmartLead campaigns before activation
GTM_MCP_USER_EMAIL=

# Optional — proxy for scraping blocked sites
GTM_MCP_APIFY_PROXY_PASSWORD=

# Optional — Google Sheets export (contacts CRM, reply logging)
# Service account JSON — either inline string or file path:
GOOGLE_SERVICE_ACCOUNT_JSON=
# OR: path to credentials file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json
# Shared Drive ID (required if using Google Sheets — personal drive forbidden):
GOOGLE_SHARED_DRIVE_ID=
